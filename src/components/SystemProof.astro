---
---

<section id="system-proof" class="py-[7.5rem] bg-[#0A0A0A] relative overflow-hidden border-t border-white/5">

  <div class="max-w-5xl mx-auto px-6 relative z-10">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <div class="section-label mb-6">What You Get</div>
      <h2 class="font-black tracking-tight text-balance mb-5" style="font-size: clamp(2rem, 5vw, 4rem); line-height: 1.05;">
        What Happens After<br/>
        <span class="text-[#D4AF37]">You Hit Submit.</span>
      </h2>
      <p class="max-w-xl mx-auto leading-relaxed" style="color: rgba(255,255,255,0.45); font-size: clamp(0.95rem, 2vw, 1.1rem);">
        You don't just fill out a form. You step into an automated system built to respond, qualify, and close — starting the moment you submit.
      </p>
    </div>

    <!-- Steps grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-14">

      <!-- Step 01 -->
      <div class="reveal reveal-d1 bg-[#111] border border-white/8 rounded-sm p-7 group hover:border-[#D4AF37]/25 transition-colors duration-300 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#D4AF37]/30 to-transparent"></div>
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0 font-black text-base" style="background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.2); color: #D4AF37;">01</div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest mb-2" style="color: rgba(212,175,55,0.5);">Immediately</div>
            <h3 class="text-lg font-black text-white mb-2">Confirmation Email Sent</h3>
            <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">
              A branded confirmation lands in your inbox within 30 seconds. Your audit is logged, your data is secure, and the system is already moving.
            </p>
          </div>
        </div>
      </div>

      <!-- Step 02 -->
      <div class="reveal reveal-d2 bg-[#111] border border-white/8 rounded-sm p-7 group hover:border-[#00FF41]/20 transition-colors duration-300 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#00FF41]/20 to-transparent"></div>
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0 font-black text-base" style="background: rgba(0,255,65,0.08); border: 1px solid rgba(0,255,65,0.2); color: #00FF41;">02</div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest mb-2" style="color: rgba(0,255,65,0.5);">&lt; 30 Seconds</div>
            <h3 class="text-lg font-black text-white mb-2">AI Analyzes Your Profile</h3>
            <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">
              Our conversion stack maps your business type, ad spend, and lead volume to calculate your exact monthly revenue leak and infrastructure gap.
            </p>
          </div>
        </div>
      </div>

      <!-- Step 03 -->
      <div class="reveal reveal-d1 bg-[#111] border border-white/8 rounded-sm p-7 group hover:border-[#00FF41]/20 transition-colors duration-300 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#00FF41]/20 to-transparent"></div>
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0 font-black text-base" style="background: rgba(0,255,65,0.08); border: 1px solid rgba(0,255,65,0.2); color: #00FF41;">03</div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest mb-2" style="color: rgba(0,255,65,0.5);">Within 24 Hours</div>
            <h3 class="text-lg font-black text-white mb-2">Personal Revenue Report</h3>
            <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">
              Your custom Revenue Leakage Report lands in your inbox — naming the exact gaps, the estimated monthly cost, and the infrastructure needed to fix it.
            </p>
          </div>
        </div>
      </div>

      <!-- Step 04 -->
      <div class="reveal reveal-d2 bg-[#111] border border-white/8 rounded-sm p-7 group hover:border-[#D4AF37]/25 transition-colors duration-300 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-[#D4AF37]/30 to-transparent"></div>
        <div class="flex items-start gap-5">
          <div class="w-12 h-12 rounded-sm flex items-center justify-center flex-shrink-0 font-black text-base" style="background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.2); color: #D4AF37;">04</div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest mb-2" style="color: rgba(212,175,55,0.5);">Your Call</div>
            <h3 class="text-lg font-black text-white mb-2">Strategy Call Scheduled</h3>
            <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.45);">
              A LeverageSystems specialist walks you through your findings, answers every question, and maps the fastest path from where you are to fully autonomous.
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom CTA -->
    <div class="text-center reveal">
      <a href="#diagnostic" class="neon-btn inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold rounded-sm w-full sm:w-auto">
        Get My Revenue Audit
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
