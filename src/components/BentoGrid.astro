---
---

<section id="engine" class="py-[7.5rem] bg-[#0A0A0A] relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <div class="section-label mb-6">The Solution</div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black tracking-tight text-balance">
        The Revenue <span class="text-[#00FF41]">Recovery Engine</span>
      </h2>
      <p class="text-white/50 mt-5 text-lg max-w-xl mx-auto">
        Three interlocking systems that turn your ad spend from a cost center into a compounding asset.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-12 gap-5 auto-rows-auto">

      <!-- Card 1: Instant Speed-to-Lead (Large, left) -->
      <div class="bento-card reveal reveal-d1 col-span-12 md:col-span-7 p-6 sm:p-8 md:p-10 rounded-sm relative overflow-hidden group">
        <!-- Background glow -->
        <div class="absolute top-0 left-0 w-64 h-64 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
          style="background: radial-gradient(circle, rgba(0,255,65,0.08) 0%, transparent 70%);">
        </div>

        <!-- Icon -->
        <div class="w-14 h-14 rounded-sm bg-[#00FF41]/10 border border-[#00FF41]/20 flex items-center justify-center mb-6">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00FF41" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>

        <!-- Tag -->
        <div class="text-xs text-[#00FF41]/60 font-mono uppercase tracking-widest mb-3">Module 01</div>

        <h3 class="text-2xl md:text-3xl font-black mb-3">Instant Speed-to-Lead</h3>
        <p class="text-white/50 text-base leading-relaxed mb-8 max-w-md">
          The moment a lead submits, our AI engages them with a personalized, context-aware conversation — before a human rep even sees the notification. No more lead decay.
        </p>

        <!-- Live metric display -->
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-[#0A0A0A] border border-white/5 rounded-sm p-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-1.5 h-1.5 rounded-full bg-[#00FF41] animate-pulse-green"></span>
              <span class="text-xs text-white/40 font-mono uppercase tracking-wide">Response Time</span>
            </div>
            <div class="text-3xl font-black text-[#00FF41] tabular-nums">&lt;30s</div>
          </div>
          <div class="bg-[#0A0A0A] border border-white/5 rounded-sm p-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="w-1.5 h-1.5 rounded-full bg-white/30"></span>
              <span class="text-xs text-white/40 font-mono uppercase tracking-wide">Qualification Rate</span>
            </div>
            <div class="text-3xl font-black text-white tabular-nums">94%</div>
          </div>
        </div>

        <!-- Visual: timeline -->
        <div class="mt-6 flex items-center gap-0">
          <div class="flex flex-col items-center">
            <div class="w-8 h-8 rounded-full bg-[#00FF41] flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="3">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </div>
            <div class="text-[10px] text-[#00FF41]/60 mt-1 font-mono">Lead In</div>
          </div>
          <div class="flex-1 h-px bg-gradient-to-r from-[#00FF41]/40 to-[#00FF41]/10 mx-2"></div>
          <div class="flex flex-col items-center">
            <div class="w-8 h-8 rounded-full bg-[#00FF41]/20 border border-[#00FF41]/40 flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00FF41" stroke-width="2.5">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div class="text-[10px] text-white/30 mt-1 font-mono">AI Engages</div>
          </div>
          <div class="flex-1 h-px bg-gradient-to-r from-[#00FF41]/10 to-[#00FF41]/40 mx-2"></div>
          <div class="flex flex-col items-center">
            <div class="w-8 h-8 rounded-full bg-[#00FF41]/20 border border-[#00FF41]/40 flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00FF41" stroke-width="2.5">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </div>
            <div class="text-[10px] text-white/30 mt-1 font-mono">Booked</div>
          </div>
        </div>
      </div>

      <!-- Card 2: Qualified Booking (Right, top) -->
      <div class="bento-card reveal reveal-d2 col-span-12 md:col-span-5 p-6 sm:p-8 rounded-sm relative overflow-hidden group">
        <div class="absolute bottom-0 right-0 w-48 h-48 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
          style="background: radial-gradient(circle, rgba(0,255,65,0.06) 0%, transparent 70%);">
        </div>

        <div class="w-14 h-14 rounded-sm bg-white/5 border border-white/10 flex items-center justify-center mb-6">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>

        <div class="text-xs text-white/30 font-mono uppercase tracking-widest mb-3">Module 02</div>
        <h3 class="text-2xl font-black mb-3">Qualified Booking</h3>
        <p class="text-white/50 text-sm leading-relaxed mb-6">
          Our AI runs discovery, scores intent, and syncs booked meetings directly to your CRM — only warm, qualified leads reach your calendar.
        </p>

        <!-- CRM logos strip -->
        <div class="flex flex-wrap items-center gap-2 mb-6">
          <div class="flex items-center px-3 py-1.5 bg-white/5 border border-white/10 rounded text-xs text-white/40 font-mono">
            GoHighLevel
          </div>
          <div class="flex items-center px-3 py-1.5 bg-white/5 border border-white/10 rounded text-xs text-white/40 font-mono">
            HubSpot
          </div>
          <div class="flex items-center px-3 py-1.5 bg-white/5 border border-white/10 rounded text-xs text-white/40 font-mono">
            Close
          </div>
        </div>

        <div class="bg-[#0A0A0A] border border-white/5 rounded-sm p-4 flex items-center justify-between">
          <div>
            <div class="text-xs text-white/30 font-mono uppercase tracking-wide mb-1">Qualified Calls / Week</div>
            <div class="text-2xl font-black text-white">+340%</div>
          </div>
          <div class="w-10 h-10 rounded-full bg-[#00FF41]/15 border border-[#00FF41]/25 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#00FF41" stroke-width="2.5">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
              <polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Card 3: Infinite Memory (Full width, bottom) -->
      <div class="bento-card reveal reveal-d1 col-span-12 p-6 sm:p-8 md:p-10 rounded-sm relative overflow-hidden group">
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
          style="background: radial-gradient(ellipse at 50% 100%, rgba(0,255,65,0.04) 0%, transparent 60%);">
        </div>

        <div class="flex flex-col md:flex-row md:items-start gap-8">
          <!-- Left -->
          <div class="md:w-2/5">
            <div class="w-14 h-14 rounded-sm bg-[#00FF41]/10 border border-[#00FF41]/20 flex items-center justify-center mb-6">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#00FF41" stroke-width="2">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
              </svg>
            </div>
            <div class="text-xs text-[#00FF41]/60 font-mono uppercase tracking-widest mb-3">Module 03</div>
            <h3 class="text-2xl md:text-3xl font-black mb-3">Infinite Memory</h3>
            <p class="text-white/50 text-base leading-relaxed">
              Every interaction, every objection, every preference — our AI retains full context across every touchpoint. Follow-ups feel personal because they remember everything your team forgets.
            </p>
          </div>

          <!-- Right: Memory visualization -->
          <div class="md:w-3/5">
            <div class="space-y-2">
              {[
                { label: 'Lead: Marcus W.', note: 'Mentioned budget concern on Day 3 call. Revisit after Q2 close.', days: '14d ago', active: true },
                { label: 'Lead: Sarah K.', note: 'Decision maker is her CFO. Needs ROI case study. Sent deck v2.', days: '7d ago', active: true },
                { label: 'Lead: David R.', note: 'Hot lead — ready to move. Awaiting contract review.', days: '2d ago', active: true },
                { label: 'Lead: Priya M.', note: 'Follow up scheduled for Monday at 2pm EST after demo.', days: 'Today', active: false },
              ].map((item, i) => (
                <div class={`flex items-start gap-4 p-4 rounded-sm border ${item.active ? 'bg-[#0A0A0A] border-white/5' : 'bg-[#00FF41]/5 border-[#00FF41]/20'} transition-all`}>
                  <div class={`w-2 h-2 rounded-full mt-1.5 flex-shrink-0 ${item.active ? 'bg-white/20' : 'bg-[#00FF41] animate-pulse-green'}`}></div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2 mb-0.5">
                      <span class={`text-sm font-bold ${item.active ? 'text-white/70' : 'text-[#00FF41]'}`}>{item.label}</span>
                      <span class="text-[10px] text-white/25 font-mono flex-shrink-0">{item.days}</span>
                    </div>
                    <p class="text-xs text-white/40 leading-relaxed truncate">{item.note}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-4 flex items-center gap-3">
              <div class="flex-1 h-px bg-white/5"></div>
              <span class="text-xs text-white/20 font-mono">+247 more follow-ups queued</span>
              <div class="flex-1 h-px bg-white/5"></div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom stat bar -->
    <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4 reveal">
      {[
        { value: '100%', label: 'Lead Coverage' },
        { value: '0', label: 'Follow-ups Missed' },
        { value: '18s', label: 'Median Response' },
        { value: '∞', label: 'Scalability' },
      ].map(stat => (
        <div class="bg-[#111] border border-white/5 rounded-sm px-6 py-5 text-center">
          <div class="text-2xl font-black text-[#00FF41]">{stat.value}</div>
          <div class="text-xs text-white/30 mt-1 uppercase tracking-wider font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
