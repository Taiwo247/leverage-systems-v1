---
---

<section class="py-12 border-y border-white/5 bg-[#0A0A0A] overflow-hidden">
  <p class="text-center text-xs text-white/25 font-mono uppercase tracking-widest mb-8">
    Engineered to integrate with your existing ecosystem
  </p>

  <div class="relative">
    <!-- Fade masks -->
    <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none"
      style="background: linear-gradient(to right, #0A0A0A, transparent);">
    </div>
    <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none"
      style="background: linear-gradient(to left, #0A0A0A, transparent);">
    </div>

    <!-- Scrolling track -->
    <div class="flex animate-trust-marquee gap-16 whitespace-nowrap w-max">
      <!-- Set 1 -->
      <div class="flex items-center gap-16 flex-shrink-0">

        <!-- Shopify -->
        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="24" height="24" viewBox="0 0 109 124" fill="white">
            <path d="M74.7 14.8s-.3-1.5-1.4-2.1c-.9-.5-2.3-.4-2.3-.4s-1.3-.1-3.5-.3c-.2-1.4-.7-3.4-1.7-5.3C63.9 3.3 61 1 57.1 1c-.3 0-.5 0-.8.1-.1-.1-.2-.2-.3-.3C54.5-.1 52.6-.3 50.8.4c-4 1.5-5.9 5.6-6.7 9.2-1.9.6-3.3 1-3.3 1s-2.1.7-2.2 2.7L36 88.7l38.5 7.3L90 90.4 74.7 14.8zM57.5 7.1c-.1.1-.2.1-.3.2-.8-2.1-2-3.5-3.6-4.3 1.7.1 3 1.5 3.9 4.1zM50.4 3.4c2.7-.9 4.9.5 6.5 3.5.1.2.2.4.3.7-2.3.7-4.7 1.4-7.2 2.2.7-3 2-5.2 2.8-5.7-.1-.2-.2-.5-.4-.7zm-2 .5c-.1.1-.3.3-.4.5-.7 1.3-1.4 3.3-1.7 6.1-1.4.4-2.7.8-3.9 1.2.9-3.5 2.5-6.6 6-7.8z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Shopify</span>
        </div>

        <!-- Meta -->
        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="28" height="16" viewBox="0 0 60 30" fill="white">
            <path d="M30 15C30 6.716 23.284 0 15 0S0 6.716 0 15s6.716 15 15 15c3.616 0 6.927-1.283 9.507-3.4A14.947 14.947 0 0 1 30 15zm0 0c0 8.284 6.716 15 15 15s15-6.716 15-15S53.284 0 45 0 30 6.716 30 15z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Meta</span>
        </div>

        <!-- Stripe -->
        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Stripe</span>
        </div>

        <!-- Google Ads -->
        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Google Ads</span>
        </div>

        <!-- GoHighLevel -->
        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">GoHighLevel</span>
        </div>

        <!-- HubSpot -->
        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M18.164 7.93V5.084a2.198 2.198 0 0 0 1.268-1.978V3.08A2.2 2.2 0 0 0 17.234.88h-.025a2.2 2.2 0 0 0-2.197 2.2v.025a2.198 2.198 0 0 0 1.268 1.978V7.93a6.232 6.232 0 0 0-2.963 1.306L5.3 3.79a2.452 2.452 0 1 0-1.273 1.498l7.84 5.348a6.234 6.234 0 0 0-.922 3.27c0 1.19.334 2.3.913 3.245l-2.39 2.39a1.96 1.96 0 0 0-.571-.09 1.998 1.998 0 1 0 1.998 1.998c0-.21-.035-.41-.09-.602l2.362-2.362a6.232 6.232 0 1 0 4.997-10.655zm-.97 9.468a3.245 3.245 0 1 1 0-6.49 3.245 3.245 0 0 1 0 6.49z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">HubSpot</span>
        </div>

      </div>

      <!-- Set 2 (duplicate for seamless loop) -->
      <div class="flex items-center gap-16 flex-shrink-0">

        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="24" height="24" viewBox="0 0 109 124" fill="white">
            <path d="M74.7 14.8s-.3-1.5-1.4-2.1c-.9-.5-2.3-.4-2.3-.4s-1.3-.1-3.5-.3c-.2-1.4-.7-3.4-1.7-5.3C63.9 3.3 61 1 57.1 1c-.3 0-.5 0-.8.1-.1-.1-.2-.2-.3-.3C54.5-.1 52.6-.3 50.8.4c-4 1.5-5.9 5.6-6.7 9.2-1.9.6-3.3 1-3.3 1s-2.1.7-2.2 2.7L36 88.7l38.5 7.3L90 90.4 74.7 14.8z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Shopify</span>
        </div>

        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="28" height="16" viewBox="0 0 60 30" fill="white">
            <path d="M30 15C30 6.716 23.284 0 15 0S0 6.716 0 15s6.716 15 15 15c3.616 0 6.927-1.283 9.507-3.4A14.947 14.947 0 0 1 30 15zm0 0c0 8.284 6.716 15 15 15s15-6.716 15-15S53.284 0 45 0 30 6.716 30 15z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Meta</span>
        </div>

        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M13.976 9.15c-2.172-.806-3.356-1.426-3.356-2.409 0-.831.683-1.305 1.901-1.305 2.227 0 4.515.858 6.09 1.631l.89-5.494C18.252.975 15.697 0 12.165 0 9.667 0 7.589.654 6.104 1.872 4.56 3.147 3.757 4.992 3.757 7.218c0 4.039 2.467 5.76 6.476 7.219 2.585.92 3.445 1.574 3.445 2.583 0 .98-.84 1.545-2.354 1.545-1.875 0-4.965-.921-6.99-2.109l-.9 5.555C5.175 22.99 8.385 24 11.714 24c2.641 0 4.843-.624 6.328-1.813 1.664-1.305 2.525-3.236 2.525-5.732 0-4.128-2.524-5.851-6.591-7.305z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Stripe</span>
        </div>

        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">Google Ads</span>
        </div>

        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">GoHighLevel</span>
        </div>

        <div class="flex items-center gap-2.5 opacity-25 hover:opacity-50 transition-opacity duration-300 grayscale">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M18.164 7.93V5.084a2.198 2.198 0 0 0 1.268-1.978V3.08A2.2 2.2 0 0 0 17.234.88h-.025a2.2 2.2 0 0 0-2.197 2.2v.025a2.198 2.198 0 0 0 1.268 1.978V7.93a6.232 6.232 0 0 0-2.963 1.306L5.3 3.79a2.452 2.452 0 1 0-1.273 1.498l7.84 5.348a6.234 6.234 0 0 0-.922 3.27c0 1.19.334 2.3.913 3.245l-2.39 2.39a1.96 1.96 0 0 0-.571-.09 1.998 1.998 0 1 0 1.998 1.998c0-.21-.035-.41-.09-.602l2.362-2.362a6.232 6.232 0 1 0 4.997-10.655zm-.97 9.468a3.245 3.245 0 1 1 0-6.49 3.245 3.245 0 0 1 0 6.49z"/>
          </svg>
          <span class="text-white font-semibold text-lg tracking-tight" style="font-family: 'Space Grotesk', sans-serif;">HubSpot</span>
        </div>

      </div>
    </div>
  </div>
</section>
