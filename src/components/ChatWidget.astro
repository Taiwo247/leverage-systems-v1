---
---

<!-- Floating Chat Widget -->
<div id="chat-widget" class="fixed bottom-6 right-6 z-[200] flex flex-col items-end gap-3">

  <!-- Chat Panel -->
  <div id="chat-panel"
    class="hidden flex-col w-[340px] max-w-[calc(100vw-3rem)] rounded-sm overflow-hidden"
    style="height: 460px; background: #111111; border: 1px solid rgba(212,175,55,0.25); box-shadow: 0 25px 60px rgba(0,0,0,0.7), 0 0 40px rgba(212,175,55,0.06);">

    <!-- Gold top accent -->
    <div style="height:2px; background: linear-gradient(to right, transparent, #D4AF37, transparent); flex-shrink:0;"></div>

    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-3 flex-shrink-0" style="border-bottom: 1px solid rgba(255,255,255,0.06); background: #0F0F0F;">
      <div class="flex items-center gap-2.5">
        <div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0" style="background: rgba(212,175,55,0.12); border: 1px solid rgba(212,175,55,0.3);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2.5" aria-hidden="true">
            <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 5v5l3 3"/>
          </svg>
        </div>
        <div>
          <div class="text-white font-bold text-sm leading-none">LeverageSystems AI</div>
          <div class="flex items-center gap-1 mt-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-[#00FF41] animate-pulse-green"></span>
            <span class="text-[10px] font-mono" style="color: rgba(255,255,255,0.35);">Online</span>
          </div>
        </div>
      </div>
      <button id="chat-close" class="p-1.5 rounded text-white/30 hover:text-white/70 transition-colors" aria-label="Close chat">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3" style="scrollbar-width: thin; scrollbar-color: rgba(212,175,55,0.2) transparent;">
      <!-- Initial message -->
      <div class="flex gap-2.5 items-start">
        <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5" style="background: rgba(212,175,55,0.15); border: 1px solid rgba(212,175,55,0.25);">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2.5" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4l2 2"/>
          </svg>
        </div>
        <div class="chat-bubble-ai text-sm leading-relaxed" style="background: #1A1A1A; border: 1px solid rgba(255,255,255,0.07); border-radius: 0 8px 8px 8px; padding: 10px 13px; color: rgba(255,255,255,0.8); max-width: 85%;">
          Hey — I'm the LeverageSystems AI. Ask me anything about how we work, our results, or whether we're a fit. I'll give you straight answers.
        </div>
      </div>
    </div>

    <!-- Gate message (hidden until limit hit) -->
    <div id="chat-gate" class="hidden px-4 py-3 flex-shrink-0" style="border-top: 1px solid rgba(212,175,55,0.15); background: rgba(212,175,55,0.05);">
      <p class="text-xs text-center mb-2.5" style="color: rgba(255,255,255,0.5);">Ready to see your exact revenue leak?</p>
      <a href="#diagnostic" id="chat-gate-cta"
        class="neon-btn block w-full text-center py-2.5 text-sm font-bold rounded-sm">
        Run My Free Revenue Audit →
      </a>
    </div>

    <!-- Input -->
    <div id="chat-input-area" class="flex items-center gap-2 px-3 py-3 flex-shrink-0" style="border-top: 1px solid rgba(255,255,255,0.06);">
      <input
        id="chat-input"
        type="text"
        placeholder="Ask anything..."
        autocomplete="off"
        class="flex-1 bg-transparent text-sm text-white placeholder-white/25 outline-none"
        style="font-family: 'Inter', sans-serif;"
      />
      <button id="chat-send" class="flex-shrink-0 w-8 h-8 rounded-sm flex items-center justify-center transition-all" style="background: #D4AF37;" aria-label="Send message">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2.5" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Toggle Button -->
  <button id="chat-toggle"
    class="w-14 h-14 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-105"
    style="background: #111; border: 1.5px solid rgba(212,175,55,0.5); box-shadow: 0 0 20px rgba(212,175,55,0.25), 0 8px 24px rgba(0,0,0,0.5);"
    aria-label="Open chat">
    <!-- Chat icon (shown when closed) -->
    <svg id="icon-chat" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2" aria-hidden="true">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
    <!-- Close icon (shown when open) -->
    <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2.5" class="hidden" aria-hidden="true">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>
</div>

<script>
  const panel       = document.getElementById('chat-panel');
  const toggle      = document.getElementById('chat-toggle');
  const closeBtn    = document.getElementById('chat-close');
  const input       = document.getElementById('chat-input') as HTMLInputElement | null;
  const sendBtn     = document.getElementById('chat-send');
  const messages    = document.getElementById('chat-messages');
  const gate        = document.getElementById('chat-gate');
  const inputArea   = document.getElementById('chat-input-area');
  const iconChat    = document.getElementById('icon-chat');
  const iconClose   = document.getElementById('icon-close');
  const gateCta     = document.getElementById('chat-gate-cta');

  let isOpen        = false;
  let isLoading     = false;
  let userTurns     = 0;
  const MAX_TURNS   = 6;
  const history: { role: 'user' | 'assistant'; content: string }[] = [];

  function openChat() {
    isOpen = true;
    panel?.classList.remove('hidden');
    panel?.classList.add('flex');
    iconChat?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    scrollToBottom();
    input?.focus();
  }

  function closeChat() {
    isOpen = false;
    panel?.classList.add('hidden');
    panel?.classList.remove('flex');
    iconChat?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  function scrollToBottom() {
    if (messages) messages.scrollTop = messages.scrollHeight;
  }

  function appendMessage(role: 'user' | 'assistant', text: string) {
    if (!messages) return;
    const wrap = document.createElement('div');

    if (role === 'user') {
      wrap.className = 'flex justify-end';
      wrap.innerHTML = `
        <div style="background: rgba(212,175,55,0.12); border: 1px solid rgba(212,175,55,0.2); border-radius: 8px 0 8px 8px; padding: 10px 13px; color: rgba(255,255,255,0.85); max-width: 85%; font-size: 0.875rem; line-height: 1.5;">
          ${text.replace(/</g, '&lt;')}
        </div>`;
    } else {
      wrap.className = 'flex gap-2.5 items-start';
      wrap.innerHTML = `
        <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5" style="background: rgba(212,175,55,0.15); border: 1px solid rgba(212,175,55,0.25);">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l2 2"/></svg>
        </div>
        <div style="background: #1A1A1A; border: 1px solid rgba(255,255,255,0.07); border-radius: 0 8px 8px 8px; padding: 10px 13px; color: rgba(255,255,255,0.8); max-width: 85%; font-size: 0.875rem; line-height: 1.5;">
          ${text.replace(/</g, '&lt;')}
        </div>`;
    }

    messages.appendChild(wrap);
    scrollToBottom();
  }

  function showTyping() {
    if (!messages) return null;
    const wrap = document.createElement('div');
    wrap.id = 'typing-indicator';
    wrap.className = 'flex gap-2.5 items-start';
    wrap.innerHTML = `
      <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5" style="background: rgba(212,175,55,0.15); border: 1px solid rgba(212,175,55,0.25);">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l2 2"/></svg>
      </div>
      <div style="background: #1A1A1A; border: 1px solid rgba(255,255,255,0.07); border-radius: 0 8px 8px 8px; padding: 10px 13px; display:flex; gap:4px; align-items:center;">
        <span style="width:6px;height:6px;border-radius:50%;background:rgba(212,175,55,0.5);animation:blink-cursor 1s step-end infinite;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:rgba(212,175,55,0.5);animation:blink-cursor 1s step-end infinite 0.2s;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:rgba(212,175,55,0.5);animation:blink-cursor 1s step-end infinite 0.4s;"></span>
      </div>`;
    messages.appendChild(wrap);
    scrollToBottom();
    return wrap;
  }

  function showGate() {
    gate?.classList.remove('hidden');
    inputArea?.classList.add('hidden');
  }

  async function sendMessage() {
    if (!input || isLoading || !input.value.trim()) return;
    const text = input.value.trim();
    input.value = '';

    appendMessage('user', text);
    history.push({ role: 'user', content: text });
    userTurns++;

    isLoading = true;
    const typingEl = showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: history, count: userTurns }),
      });
      const data = await res.json();
      typingEl?.remove();

      const reply = data.message ?? 'Something went wrong. Try again.';
      appendMessage('assistant', reply);
      history.push({ role: 'assistant', content: reply });

      if (data.gated || userTurns >= MAX_TURNS) showGate();
    } catch {
      typingEl?.remove();
      appendMessage('assistant', 'Having trouble connecting. Try again in a moment.');
    } finally {
      isLoading = false;
    }
  }

  toggle?.addEventListener('click', () => isOpen ? closeChat() : openChat());
  closeBtn?.addEventListener('click', closeChat);
  sendBtn?.addEventListener('click', sendMessage);
  input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') sendMessage(); });
  gateCta?.addEventListener('click', closeChat);
</script>
