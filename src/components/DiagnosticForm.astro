---
const steps = [
  {
    id: 1,
    label: 'Business Profile',
    question: 'What type of business are you scaling?',
    subtitle: 'We tailor the infrastructure to your specific lead flow.',
    type: 'cards',
    options: [
      { value: 'coaching', label: 'Coaching / Consulting', icon: '🎯' },
      { value: 'agency', label: 'Marketing Agency', icon: '📈' },
      { value: 'saas', label: 'SaaS / Software', icon: '⚡' },
      { value: 'ecom', label: 'E-commerce / DTC', icon: '🛒' },
      { value: 'real-estate', label: 'Real Estate', icon: '🏢' },
      { value: 'other', label: 'Other High-Ticket', icon: '💼' },
    ],
  },
  {
    id: 2,
    label: 'Revenue Profile',
    question: 'What is your current monthly ad spend?',
    subtitle: 'This determines how much revenue is currently leaking.',
    type: 'cards',
    options: [
      { value: '0-5k', label: '$0 – $5K / mo', icon: '○' },
      { value: '5-15k', label: '$5K – $15K / mo', icon: '◎' },
      { value: '15-50k', label: '$15K – $50K / mo', icon: '◉' },
      { value: '50-100k', label: '$50K – $100K / mo', icon: '●' },
      { value: '100k+', label: '$100K+ / mo', icon: '⬤' },
    ],
  },
  {
    id: 3,
    label: 'Lead Volume',
    question: 'How many inbound leads do you receive monthly?',
    subtitle: 'Every uncontacted lead is a direct revenue loss.',
    type: 'cards',
    options: [
      { value: '<50', label: 'Under 50', icon: '○' },
      { value: '50-200', label: '50 – 200', icon: '◐' },
      { value: '200-500', label: '200 – 500', icon: '◕' },
      { value: '500+', label: '500+', icon: '●' },
    ],
  },
  {
    id: 4,
    label: 'Current Stack',
    question: 'What CRM / booking system do you use?',
    subtitle: 'We integrate natively with your current tools.',
    type: 'cards',
    options: [
      { value: 'ghl', label: 'GoHighLevel', icon: '⚡' },
      { value: 'hubspot', label: 'HubSpot', icon: '🔶' },
      { value: 'calendly', label: 'Calendly / Cal.com', icon: '📅' },
      { value: 'close', label: 'Close CRM', icon: '🔐' },
      { value: 'spreadsheet', label: 'Spreadsheet / None', icon: '📊' },
      { value: 'other', label: 'Other', icon: '🔌' },
    ],
  },
  {
    id: 5,
    label: 'Contact',
    question: 'Where should we send your Revenue Audit?',
    subtitle: 'We personally review every submission and respond within 24 hours.',
    type: 'contact',
  },
];
---

<section id="diagnostic" class="py-[7.5rem] bg-[#0A0A0A] relative overflow-hidden">
  <!-- Green ambient glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] opacity-[0.05] pointer-events-none"
    style="background: radial-gradient(circle, #00FF41 0%, transparent 70%);">
  </div>

  <div class="relative z-10 max-w-2xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12 reveal">
      <div class="section-label mb-6">Revenue Audit</div>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
        Run Your Free<br/><span class="text-[#00FF41]">Diagnostic</span>
      </h2>
      <p class="text-white/50 text-base max-w-md mx-auto">
        Takes 90 seconds. We calculate your exact monthly leak and whether Leverage Systems is the right fit.
      </p>

      <!-- Filter notice -->
      <div class="inline-flex items-center gap-2 mt-5 px-4 py-2 bg-[#111] border border-white/10 rounded-sm text-xs text-white/30 font-mono">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        We only work with operators doing $10K+/mo. Others will be redirected.
      </div>
    </div>

    <!-- Form card -->
    <div class="bg-[#111] border border-white/8 rounded-sm overflow-hidden reveal reveal-d1">

      <!-- Progress bar -->
      <div class="h-1 bg-white/5 relative">
        <div
          id="progress-bar"
          class="h-full bg-[#00FF41] transition-all duration-500"
          style="width: 20%;"
        ></div>
      </div>

      <!-- Step counter -->
      <div class="flex items-center justify-between px-5 sm:px-8 pt-6 pb-0">
        <div id="step-label" class="text-xs text-[#00FF41]/70 font-mono uppercase tracking-widest">
          Step 1 of 5 — Business Profile
        </div>
        <div class="text-xs text-white/20 font-mono flex-shrink-0 ml-2" id="step-counter">01 / 05</div>
      </div>

      <!-- Steps container -->
      <div id="form-steps" class="px-5 sm:px-8 pb-6 sm:pb-8 pt-6">

        <!-- Steps will be rendered by JS -->
        <div id="step-content" class="min-h-[280px]">
          <!-- Dynamic content inserted here -->
        </div>

        <!-- Navigation -->
        <div class="flex items-center justify-between mt-8 pt-6 border-t border-white/5">
          <button
            id="btn-back"
            class="flex items-center gap-2 text-sm text-white/30 hover:text-white/60 transition-colors font-medium disabled:opacity-20"
            disabled
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back
          </button>
          <button
            id="btn-next"
            class="neon-btn flex items-center gap-2 px-7 py-3 text-sm font-bold rounded-sm"
          >
            Continue
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Trust signals -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-xs text-white/20 font-mono">
      <span class="flex items-center gap-1.5">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        256-bit encrypted
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        No spam, ever
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        Response within 24h
      </span>
    </div>
  </div>
</section>

<script>
  const steps = [
    {
      id: 1,
      label: 'Business Profile',
      question: 'What type of business are you scaling?',
      subtitle: 'We tailor the infrastructure to your specific lead flow.',
      type: 'cards',
      options: [
        { value: 'coaching', label: 'Coaching / Consulting', emoji: '🎯' },
        { value: 'agency', label: 'Marketing Agency', emoji: '📈' },
        { value: 'saas', label: 'SaaS / Software', emoji: '⚡' },
        { value: 'ecom', label: 'E-commerce / DTC', emoji: '🛒' },
        { value: 'real-estate', label: 'Real Estate', emoji: '🏢' },
        { value: 'other', label: 'Other High-Ticket', emoji: '💼' },
      ],
    },
    {
      id: 2,
      label: 'Revenue Profile',
      question: 'What is your current monthly ad spend?',
      subtitle: 'This determines how much revenue is currently leaking.',
      type: 'cards',
      options: [
        { value: '0-5k', label: '$0 – $5K / mo', emoji: null },
        { value: '5-15k', label: '$5K – $15K / mo', emoji: null },
        { value: '15-50k', label: '$15K – $50K / mo', emoji: null },
        { value: '50-100k', label: '$50K – $100K / mo', emoji: null },
        { value: '100k+', label: '$100K+ / mo', emoji: null },
      ],
    },
    {
      id: 3,
      label: 'Lead Volume',
      question: 'How many inbound leads do you receive monthly?',
      subtitle: 'Every uncontacted lead is a direct revenue loss.',
      type: 'cards',
      options: [
        { value: '<50', label: 'Under 50', emoji: null },
        { value: '50-200', label: '50 – 200', emoji: null },
        { value: '200-500', label: '200 – 500', emoji: null },
        { value: '500+', label: '500+', emoji: null },
      ],
    },
    {
      id: 4,
      label: 'Current Stack',
      question: 'What CRM / booking system do you use?',
      subtitle: 'We integrate natively with your current tools.',
      type: 'cards',
      options: [
        { value: 'ghl', label: 'GoHighLevel', emoji: '⚡' },
        { value: 'hubspot', label: 'HubSpot', emoji: '🔶' },
        { value: 'calendly', label: 'Calendly / Cal.com', emoji: '📅' },
        { value: 'close', label: 'Close CRM', emoji: '🔐' },
        { value: 'spreadsheet', label: 'Spreadsheet / None', emoji: '📊' },
        { value: 'other', label: 'Other', emoji: '🔌' },
      ],
    },
    {
      id: 5,
      label: 'Contact',
      question: 'Where should we send your Revenue Audit?',
      subtitle: 'We personally review every submission and respond within 24 hours.',
      type: 'contact',
    },
  ];

  let currentStep = 0;
  const answers = {};

  const progressBar = document.getElementById('progress-bar');
  const stepLabel = document.getElementById('step-label');
  const stepCounter = document.getElementById('step-counter');
  const stepContent = document.getElementById('step-content');
  const btnBack = document.getElementById('btn-back');
  const btnNext = document.getElementById('btn-next');

  function renderStep(idx) {
    const step = steps[idx];
    const progress = ((idx + 1) / steps.length) * 100;
    progressBar.style.width = `${progress}%`;
    stepLabel.textContent = `Step ${idx + 1} of ${steps.length} — ${step.label}`;
    stepCounter.textContent = `${String(idx + 1).padStart(2, '0')} / ${String(steps.length).padStart(2, '0')}`;
    btnBack.disabled = idx === 0;

    if (idx === steps.length - 1 && step.type !== 'contact') {
      btnNext.innerHTML = `Submit Audit <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>`;
    } else if (step.type === 'contact') {
      btnNext.innerHTML = `Submit Audit <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>`;
    } else {
      btnNext.innerHTML = `Continue <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`;
    }

    if (step.type === 'cards') {
      const cols = step.options.length <= 4 ? 'grid-cols-2' : 'grid-cols-2 sm:grid-cols-3';
      stepContent.innerHTML = `
        <div class="mb-6">
          <h3 class="text-xl font-black text-white mb-1.5">${step.question}</h3>
          <p class="text-white/40 text-sm">${step.subtitle}</p>
        </div>
        <div class="grid ${cols} gap-3">
          ${step.options.map(opt => `
            <button
              class="option-card flex flex-col items-start gap-2 p-4 rounded-sm border border-white/8 bg-[#0A0A0A] hover:border-[#00FF41]/40 hover:bg-[#00FF41]/5 transition-all text-left group"
              data-value="${opt.value}"
            >
              ${opt.emoji ? `<span class="text-xl">${opt.emoji}</span>` : '<div class="w-3 h-3 rounded-full bg-white/20 group-hover:bg-[#00FF41]/40 transition-colors"></div>'}
              <span class="text-sm font-semibold text-white/80 group-hover:text-white transition-colors leading-tight">${opt.label}</span>
            </button>
          `).join('')}
        </div>
      `;

      // Restore selected state
      if (answers[step.id]) {
        document.querySelectorAll('.option-card').forEach(card => {
          if (card.dataset.value === answers[step.id]) {
            card.classList.add('selected-card');
            card.style.borderColor = 'rgba(0, 255, 65, 0.4)';
            card.style.backgroundColor = 'rgba(0, 255, 65, 0.08)';
          }
        });
      }

      document.querySelectorAll('.option-card').forEach(card => {
        card.addEventListener('click', () => {
          document.querySelectorAll('.option-card').forEach(c => {
            c.style.borderColor = '';
            c.style.backgroundColor = '';
          });
          card.style.borderColor = 'rgba(0, 255, 65, 0.5)';
          card.style.backgroundColor = 'rgba(0, 255, 65, 0.1)';
          answers[step.id] = card.dataset.value;
        });
      });
    } else if (step.type === 'contact') {
      stepContent.innerHTML = `
        <div class="mb-6">
          <h3 class="text-xl font-black text-white mb-1.5">${step.question}</h3>
          <p class="text-white/40 text-sm">${step.subtitle}</p>
        </div>
        <div class="space-y-4">
          <div>
            <label class="block text-xs text-white/40 font-mono uppercase tracking-widest mb-2">Full Name *</label>
            <input
              id="contact-name"
              type="text"
              placeholder="Alex Johnson"
              class="w-full bg-[#0A0A0A] border border-white/10 rounded-sm px-4 py-3 text-white placeholder-white/25 focus:outline-none focus:border-[#00FF41]/40 focus:bg-[#00FF41]/5 transition-all text-sm"
              value="${answers.name || ''}"
            />
          </div>
          <div>
            <label class="block text-xs text-white/40 font-mono uppercase tracking-widest mb-2">Business Email *</label>
            <input
              id="contact-email"
              type="email"
              placeholder="you@yourcompany.com"
              class="w-full bg-[#0A0A0A] border border-white/10 rounded-sm px-4 py-3 text-white placeholder-white/25 focus:outline-none focus:border-[#00FF41]/40 focus:bg-[#00FF41]/5 transition-all text-sm"
              value="${answers.email || ''}"
            />
          </div>
          <div>
            <label class="block text-xs text-white/40 font-mono uppercase tracking-widest mb-2">WhatsApp / Phone</label>
            <input
              id="contact-phone"
              type="tel"
              placeholder="+1 (555) 000-0000"
              class="w-full bg-[#0A0A0A] border border-white/10 rounded-sm px-4 py-3 text-white placeholder-white/25 focus:outline-none focus:border-[#00FF41]/40 focus:bg-[#00FF41]/5 transition-all text-sm"
              value="${answers.phone || ''}"
            />
          </div>
          <div>
            <label class="block text-xs text-white/40 font-mono uppercase tracking-widest mb-2">Website URL</label>
            <input
              id="contact-url"
              type="url"
              placeholder="https://yoursite.com"
              class="w-full bg-[#0A0A0A] border border-white/10 rounded-sm px-4 py-3 text-white placeholder-white/25 focus:outline-none focus:border-[#00FF41]/40 focus:bg-[#00FF41]/5 transition-all text-sm"
              value="${answers.url || ''}"
            />
          </div>
        </div>
      `;
    }
  }

  // ── Secure API endpoint ──────────────────────────────────────────────────
  // Webhook URL is stored server-side in .env (MAKE_AUDIT_WEBHOOK).
  // The client never sees the raw webhook URL.
  function pushToZapier(data) {
    try {
      fetch('/api/submit-audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email:         data.email         || '',
          name:          data.name          || '',
          phone:         data.phone         || '',
          website:       data.url           || '',
          business_type: data[1]            || '',
          ad_spend:      data[2]            || '',
          lead_volume:   data[3]            || '',
          crm:           data[4]            || '',
        }),
        keepalive: true,
      });
    } catch (_) { /* fail silently — never break the UX */ }
  }

  function showSuccess() {
    progressBar.style.width = '100%';

    // Fire webhook immediately — do NOT await, do NOT block the animation
    pushToZapier({ ...answers });

    const email = answers.email || '';

    document.getElementById('form-steps').innerHTML = `
      <div id="audit-phases" class="py-8">

        <!-- ── Phase 1: Processing animation ── -->
        <div id="processing-screen" style="transition: opacity 0.35s ease;">

          <div class="flex justify-center mb-6">
            <div class="relative w-20 h-20">
              <div class="absolute inset-0 rounded-full border border-[#00FF41]/20 animate-ping" style="animation-duration:1.9s;"></div>
              <div class="absolute inset-2 rounded-full border border-[#00FF41]/30 animate-ping" style="animation-duration:1.9s; animation-delay:0.45s;"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-10 h-10 rounded-full bg-[#00FF41]/10 border border-[#00FF41]/50 flex items-center justify-center">
                  <div class="w-3 h-3 rounded-full bg-[#00FF41] animate-pulse-green"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="text-center mb-6">
            <p class="text-[#00FF41] font-mono text-sm tracking-wide leading-relaxed">
              LeverageSystems AI is analyzing your<br/>conversion architecture...
            </p>
          </div>

          <div class="bg-[#0A0A0A] border border-white/8 rounded-sm p-4 space-y-2 max-w-sm mx-auto mb-5">
            <div id="log-1" style="color:transparent; transition: color 0.4s ease;" class="flex items-center gap-2 font-mono text-xs">
              <span class="flex-shrink-0 text-[#00FF41]">▸</span> Scanning lead flow gaps...
            </div>
            <div id="log-2" style="color:transparent; transition: color 0.4s ease;" class="flex items-center gap-2 font-mono text-xs">
              <span class="flex-shrink-0 text-white/30">▸</span> Mapping conversion bottlenecks...
            </div>
            <div id="log-3" style="color:transparent; transition: color 0.4s ease;" class="flex items-center gap-2 font-mono text-xs">
              <span class="flex-shrink-0 text-white/30">▸</span> Calculating monthly revenue leak...
            </div>
            <div id="log-4" style="color:transparent; transition: color 0.4s ease;" class="flex items-center gap-2 font-mono text-xs">
              <span class="flex-shrink-0 text-white/30">▸</span> Building infrastructure blueprint...
            </div>
            <div id="log-5" style="color:transparent; transition: color 0.4s ease;" class="flex items-center gap-2 font-mono text-xs">
              <span class="flex-shrink-0 text-[#00FF41]">✓</span> Generating proprietary report...
            </div>
          </div>

          <div class="max-w-sm mx-auto px-1">
            <div class="h-px bg-white/5 rounded-full overflow-hidden">
              <div id="scan-bar" class="h-full bg-[#00FF41]" style="width:0%; transition: width 2.65s linear;"></div>
            </div>
          </div>
        </div>

        <!-- ── Phase 2: Luxury success state ── -->
        <div id="success-screen" class="text-center py-2" style="display:none; opacity:0; transition: opacity 0.45s ease;">
          <div
            class="w-20 h-20 rounded-full bg-[#00FF41]/15 border-2 border-[#00FF41]/50 flex items-center justify-center mx-auto mb-5"
            style="box-shadow: 0 0 60px rgba(0,255,65,0.22);"
          >
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#00FF41" stroke-width="2.5">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
          </div>
          <div class="text-[10px] text-[#00FF41]/50 font-mono uppercase tracking-widest mb-3">SYSTEM · AUDIT_INITIALIZED</div>
          <h3 class="text-2xl font-black text-white mb-2">Audit Initialized.</h3>
          <p class="text-white/50 text-base max-w-xs mx-auto leading-relaxed mb-1">
            Check your inbox for your proprietary Revenue Leakage Report.
          </p>
          <p class="text-[#00FF41] font-bold text-base">Welcome to the Machine.</p>
          <div class="mt-7 inline-flex items-center gap-2 px-4 py-2 bg-[#00FF41]/10 border border-[#00FF41]/25 rounded-sm text-[#00FF41] text-xs font-mono">
            <span class="w-1.5 h-1.5 rounded-full bg-[#00FF41] animate-pulse-green"></span>
            Report dispatched · ${email}
          </div>
        </div>

      </div>
    `;

    // Start the scan bar on next frame so the CSS transition fires
    requestAnimationFrame(() => {
      const bar = document.getElementById('scan-bar');
      if (bar) bar.style.width = '100%';
    });

    // Reveal log lines one by one
    const logDelays = [180, 630, 1080, 1530, 2020];
    logDelays.forEach((delay, i) => {
      setTimeout(() => {
        const el = document.getElementById(`log-${i + 1}`);
        if (!el) return;
        el.style.color = (i === 0 || i === 4)
          ? 'rgba(0, 255, 65, 0.65)'
          : 'rgba(255, 255, 255, 0.45)';
      }, delay);
    });

    // Cross-fade to success state at 2.9 s
    setTimeout(() => {
      const proc = document.getElementById('processing-screen');
      const succ = document.getElementById('success-screen');
      if (!proc || !succ) return;
      proc.style.opacity = '0';
      setTimeout(() => {
        proc.style.display = 'none';
        succ.style.display = 'block';
        // Double rAF ensures display:block has painted before opacity transition starts
        requestAnimationFrame(() => requestAnimationFrame(() => {
          succ.style.opacity = '1';
        }));
      }, 360);
    }, 2900);
  }

  btnNext.addEventListener('click', () => {
    const step = steps[currentStep];

    // Validate contact step
    if (step.type === 'contact') {
      const name = document.getElementById('contact-name')?.value.trim();
      const email = document.getElementById('contact-email')?.value.trim();
      if (!name || !email) {
        document.getElementById('contact-name').style.borderColor = name ? '' : 'rgba(255,68,68,0.5)';
        document.getElementById('contact-email').style.borderColor = email ? '' : 'rgba(255,68,68,0.5)';
        return;
      }
      answers.name = name;
      answers.email = email;
      answers.phone = document.getElementById('contact-phone')?.value;
      answers.url = document.getElementById('contact-url')?.value;
      showSuccess();
      return;
    }

    if (currentStep < steps.length - 1) {
      currentStep++;
      renderStep(currentStep);
    }
  });

  btnBack.addEventListener('click', () => {
    if (currentStep > 0) {
      currentStep--;
      renderStep(currentStep);
    }
  });

  // Init
  renderStep(0);
</script>
