---
---

<footer class="bg-[#0A0A0A] border-t border-white/5 py-16 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Top row -->
    <div class="flex flex-col md:flex-row items-start justify-between gap-10 mb-14">
      <!-- Brand -->
      <div class="max-w-xs">
        <div class="flex items-center gap-3 mb-4">
          <img src="/logo.png" alt="leverageSystems" class="logo-circle" width="36" height="36" />
          <span class="brand-name text-white tracking-tight text-xl">leverageSystems</span>
        </div>
        <p class="text-white/30 text-sm leading-relaxed">
          AI Sales Infrastructure for high-ticket operators who refuse to leave money in the pipeline.
        </p>
      </div>

      <!-- Links -->
      <div class="grid grid-cols-2 gap-x-16 gap-y-3 text-sm">
        <a href="#comparison" class="text-white/30 hover:text-white transition-colors">How It Works</a>
        <a href="#engine" class="text-white/30 hover:text-white transition-colors">Features</a>
        <a href="#results" class="text-white/30 hover:text-white transition-colors">Results</a>
        <a href="#diagnostic" class="text-white/30 hover:text-white transition-colors">Revenue Audit</a>
      </div>

      <!-- CTA block -->
      <div class="text-right hidden md:block">
        <p class="text-white/40 text-sm mb-3">Ready to stop the leak?</p>
        <a href="#diagnostic" class="neon-btn inline-flex items-center gap-2 px-6 py-3 text-sm font-bold rounded-sm">
          Run My Revenue Audit →
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div class="glow-line mb-8"></div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-white/20 font-mono">
      <div>© {new Date().getFullYear()} Leverage Systems. All rights reserved.</div>
      <div class="flex flex-wrap items-center justify-center md:justify-end gap-x-5 gap-y-2">
        <a href="#" class="hover:text-white/50 transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white/50 transition-colors">Terms of Service</a>
        <span class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#00FF41] animate-pulse-green"></span>
          Systems Operational
        </span>
      </div>
    </div>
  </div>
</footer>
