---
---

<section id="results" class="py-[7.5rem] bg-[#0A0A0A] relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.025]"
    style="background: radial-gradient(ellipse at 50% 0%, #00FF41 0%, transparent 55%);">
  </div>

  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <div class="section-label mb-6">Proof</div>
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black tracking-tight mb-5 text-balance">
        The Numbers <span class="text-[#00FF41]">Don't Lie</span>
      </h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto">
        Real results from operators who stopped leaking and started extracting.
      </p>
    </div>

    <!-- Wall of Stats -->
    <div id="stats-grid" class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-20">

      <div class="reveal reveal-d1 bg-[#111] border border-white/5 rounded-sm p-5 sm:p-7 text-center group hover:border-[#00FF41]/25 transition-colors duration-300">
        <div class="stat-value text-3xl sm:text-4xl md:text-5xl font-black text-[#00FF41] tabular-nums mb-2"
          data-target="2.4" data-suffix="M+" data-prefix="$" data-decimals="1">$0M+</div>
        <div class="text-[10px] sm:text-xs text-white/40 uppercase tracking-wider font-medium">Revenue Recovered</div>
      </div>

      <div class="reveal reveal-d2 bg-[#111] border border-white/5 rounded-sm p-5 sm:p-7 text-center group hover:border-[#00FF41]/25 transition-colors duration-300">
        <div class="stat-value text-3xl sm:text-4xl md:text-5xl font-black text-white tabular-nums mb-2"
          data-target="47" data-suffix="+" data-prefix="" data-decimals="0">0+</div>
        <div class="text-[10px] sm:text-xs text-white/40 uppercase tracking-wider font-medium">Operators Live</div>
      </div>

      <div class="reveal reveal-d3 bg-[#111] border border-white/5 rounded-sm p-5 sm:p-7 text-center group hover:border-[#00FF41]/25 transition-colors duration-300">
        <div class="stat-value text-3xl sm:text-4xl md:text-5xl font-black text-white tabular-nums mb-2"
          data-target="340" data-suffix="%" data-prefix="" data-decimals="0">0%</div>
        <div class="text-[10px] sm:text-xs text-white/40 uppercase tracking-wider font-medium">Avg. ROI / 90 Days</div>
      </div>

      <div class="reveal reveal-d1 bg-[#111] border border-white/5 rounded-sm p-5 sm:p-7 text-center group hover:border-[#00FF41]/25 transition-colors duration-300">
        <div class="stat-value text-3xl sm:text-4xl md:text-5xl font-black text-[#00FF41] tabular-nums mb-2"
          data-target="18" data-suffix="s" data-prefix="" data-decimals="0">0s</div>
        <div class="text-[10px] sm:text-xs text-white/40 uppercase tracking-wider font-medium">Avg. Lead Response</div>
      </div>

      <div class="reveal reveal-d2 bg-[#111] border border-white/5 rounded-sm p-5 sm:p-7 text-center group hover:border-[#00FF41]/25 transition-colors duration-300">
        <div class="stat-value text-3xl sm:text-4xl md:text-5xl font-black text-white tabular-nums mb-2"
          data-target="94" data-suffix="%" data-prefix="" data-decimals="0">0%</div>
        <div class="text-[10px] sm:text-xs text-white/40 uppercase tracking-wider font-medium">Qualification Rate</div>
      </div>

      <div class="reveal reveal-d3 bg-[#111] border border-white/5 rounded-sm p-5 sm:p-7 text-center group hover:border-[#00FF41]/25 transition-colors duration-300">
        <div class="stat-value text-3xl sm:text-4xl md:text-5xl font-black text-white tabular-nums mb-2"
          data-target="0" data-suffix="" data-prefix="" data-decimals="0">0</div>
        <div class="text-[10px] sm:text-xs text-white/40 uppercase tracking-wider font-medium">Follow-ups Missed</div>
      </div>

    </div>

    <!-- Glow divider -->
    <div class="glow-line mb-20 reveal"></div>

    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-20">

      <div class="reveal reveal-d1 bg-[#111] border border-white/5 rounded-sm p-6 sm:p-7 hover:border-[#00FF41]/20 transition-colors duration-300 flex flex-col">
        <div class="text-5xl text-[#00FF41]/20 leading-none mb-4 font-serif">"</div>
        <blockquote class="text-white/65 text-sm leading-relaxed flex-1 mb-6">
          We went from a 40% contact rate to 97% in three weeks. The AI doesn't sleep, doesn't take Fridays off, and never forgets a follow-up. It's the best hire we've ever made.
        </blockquote>
        <div class="flex items-center gap-3 pt-5 border-t border-white/5">
          <div class="w-9 h-9 rounded-full bg-[#00FF41]/15 border border-[#00FF41]/20 flex items-center justify-center text-[#00FF41] font-black text-sm flex-shrink-0">M</div>
          <div class="min-w-0">
            <div class="text-white font-bold text-sm">Marcus T.</div>
            <div class="text-white/35 text-xs">Agency Owner</div>
          </div>
          <div class="ml-auto flex-shrink-0 px-2.5 py-1 bg-[#00FF41]/10 border border-[#00FF41]/20 rounded text-[10px] text-[#00FF41] font-mono font-semibold">+$180K</div>
        </div>
      </div>

      <div class="reveal reveal-d2 bg-[#111] border border-white/5 rounded-sm p-6 sm:p-7 hover:border-[#00FF41]/20 transition-colors duration-300 flex flex-col">
        <div class="text-5xl text-[#00FF41]/20 leading-none mb-4 font-serif">"</div>
        <blockquote class="text-white/65 text-sm leading-relaxed flex-1 mb-6">
          I was manually chasing leads 3 hours a day. Now I check my calendar and it's stacked with pre-qualified calls. I didn't change my ads — I changed my infrastructure.
        </blockquote>
        <div class="flex items-center gap-3 pt-5 border-t border-white/5">
          <div class="w-9 h-9 rounded-full bg-[#00FF41]/15 border border-[#00FF41]/20 flex items-center justify-center text-[#00FF41] font-black text-sm flex-shrink-0">J</div>
          <div class="min-w-0">
            <div class="text-white font-bold text-sm">Jennifer R.</div>
            <div class="text-white/35 text-xs">Business Coach</div>
          </div>
          <div class="ml-auto flex-shrink-0 px-2.5 py-1 bg-[#00FF41]/10 border border-[#00FF41]/20 rounded text-[10px] text-[#00FF41] font-mono font-semibold">312% bookings</div>
        </div>
      </div>

      <div class="reveal reveal-d3 bg-[#111] border border-white/5 rounded-sm p-6 sm:p-7 hover:border-[#00FF41]/20 transition-colors duration-300 flex flex-col">
        <div class="text-5xl text-[#00FF41]/20 leading-none mb-4 font-serif">"</div>
        <blockquote class="text-white/65 text-sm leading-relaxed flex-1 mb-6">
          290% ROI in the first 60 days. I turned off two SDR positions. The system closes better at 2am than most reps do at noon. It's not just AI — it's a revenue machine.
        </blockquote>
        <div class="flex items-center gap-3 pt-5 border-t border-white/5">
          <div class="w-9 h-9 rounded-full bg-[#00FF41]/15 border border-[#00FF41]/20 flex items-center justify-center text-[#00FF41] font-black text-sm flex-shrink-0">D</div>
          <div class="min-w-0">
            <div class="text-white font-bold text-sm">David K.</div>
            <div class="text-white/35 text-xs">SaaS Founder</div>
          </div>
          <div class="ml-auto flex-shrink-0 px-2.5 py-1 bg-[#00FF41]/10 border border-[#00FF41]/20 rounded text-[10px] text-[#00FF41] font-mono font-semibold">$144K/yr saved</div>
        </div>
      </div>

    </div>

    <!-- Glow divider -->
    <div class="glow-line mb-20 reveal"></div>

    <!-- Implementation Roadmap -->
    <div>
      <div class="text-center mb-14 reveal">
        <div class="section-label mb-6">Process</div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight mb-4 text-balance">
          From Audit to Autonomous <span class="text-[#00FF41]">in 14 Days</span>
        </h2>
        <p class="text-white/50 text-lg max-w-xl mx-auto">
          No rip-and-replace. No long onboarding cycles. We install around your existing stack.
        </p>
      </div>

      <!-- 3-step path: flex with connectors -->
      <div class="flex flex-col md:flex-row items-stretch">

        <!-- Step 01: Audit -->
        <div class="reveal reveal-d1 flex-1 bg-[#111] border border-[#00FF41]/25 rounded-sm p-7">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-full bg-[#00FF41] flex items-center justify-center font-black text-black text-base flex-shrink-0">01</div>
          </div>
          <div class="text-xs text-[#00FF41]/60 font-mono uppercase tracking-widest mb-2">Days 1 – 2</div>
          <h3 class="text-2xl font-black mb-3 text-white">Audit</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            We map every gap in your lead flow and calculate your exact monthly revenue loss. You get the full leak analysis before we charge you anything.
          </p>
        </div>

        <!-- Connector: horizontal (desktop) / vertical arrow (mobile) -->
        <div class="flex md:flex-col items-center justify-center py-5 md:py-0 md:px-5 flex-shrink-0">
          <!-- Mobile: down arrow -->
          <svg class="md:hidden text-[#00FF41]/30" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
          <!-- Desktop: right arrow -->
          <div class="hidden md:flex flex-col items-center gap-1">
            <div class="w-8 h-px bg-gradient-to-r from-[#00FF41]/40 to-[#00FF41]/10"></div>
            <svg class="text-[#00FF41]/40" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <!-- Step 02: Integration -->
        <div class="reveal reveal-d2 flex-1 bg-[#111] border border-white/8 rounded-sm p-7">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-full bg-white/8 border border-white/15 flex items-center justify-center font-black text-white text-base flex-shrink-0">02</div>
          </div>
          <div class="text-xs text-white/30 font-mono uppercase tracking-widest mb-2">Days 3 – 7</div>
          <h3 class="text-2xl font-black mb-3 text-white">Integration</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            We build your custom AI system and wire it directly into your CRM, calendar, ad stack, and communication tools. Zero disruption to your current workflow.
          </p>
        </div>

        <!-- Connector -->
        <div class="flex md:flex-col items-center justify-center py-5 md:py-0 md:px-5 flex-shrink-0">
          <svg class="md:hidden text-[#00FF41]/30" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
          <div class="hidden md:flex flex-col items-center gap-1">
            <div class="w-8 h-px bg-gradient-to-r from-[#00FF41]/10 to-[#00FF41]/40"></div>
            <svg class="text-[#00FF41]/40" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </div>

        <!-- Step 03: Scale -->
        <div class="reveal reveal-d3 flex-1 bg-[#111] border border-white/8 rounded-sm p-7">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 rounded-full bg-white/8 border border-white/15 flex items-center justify-center font-black text-white text-base flex-shrink-0">03</div>
          </div>
          <div class="text-xs text-white/30 font-mono uppercase tracking-widest mb-2">Day 7+</div>
          <h3 class="text-2xl font-black mb-3 text-white">Scale</h3>
          <p class="text-white/50 text-sm leading-relaxed">
            Go live. Your AI captures, qualifies, nurtures, and books leads 24/7 — while you sleep, deliver, and grow. Every lead. Every time. Zero missed.
          </p>
        </div>

      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 reveal">
      <p class="text-white/40 text-sm mb-6">Ready to see where your revenue is leaking?</p>
      <a href="#diagnostic"
        class="neon-btn inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold rounded-sm w-full sm:w-auto">
        Run My Revenue Audit
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<script>
  // Animated stat counters — trigger once on scroll
  const statsGrid = document.getElementById('stats-grid');
  let counted = false;

  function animateCounters() {
    if (counted) return;
    counted = true;
    document.querySelectorAll('.stat-value[data-target]').forEach((el) => {
      const htmlEl = el as HTMLElement;
      const target = parseFloat(htmlEl.dataset.target ?? '0');
      const suffix = htmlEl.dataset.suffix ?? '';
      const prefix = htmlEl.dataset.prefix ?? '';
      const decimals = parseInt(htmlEl.dataset.decimals ?? '0');
      const duration = 1600;
      const startTime = performance.now();

      function tick(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
        const current = target * eased;
        htmlEl.textContent = prefix + current.toFixed(decimals) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    });
  }

  const counterObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        animateCounters();
        counterObserver.disconnect();
      }
    },
    { threshold: 0.25 }
  );
  if (statsGrid) counterObserver.observe(statsGrid);
</script>
