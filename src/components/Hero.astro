---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#0A0A0A] pt-20">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.025]"
    style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <!-- Green radial glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full opacity-[0.06]"
    style="background: radial-gradient(circle, #00FF41 0%, transparent 70%);">
  </div>

  <!-- Ticker tape (social proof) -->
  <div class="absolute top-20 left-0 right-0 overflow-hidden border-b border-white/5 py-3 bg-[#0A0A0A]/80 backdrop-blur-sm z-10">
    <div class="animate-ticker flex gap-20 whitespace-nowrap">
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">$2.4M Revenue Recovered Q1 2026</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">47+ High-Ticket Operators Deployed</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">Average 340% ROI in 90 Days</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">Lead Response Time: 18 Seconds</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
      <!-- Duplicate for seamless loop -->
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">$2.4M Revenue Recovered Q1 2026</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">47+ High-Ticket Operators Deployed</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">Average 340% ROI in 90 Days</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
      <span class="text-white/30 text-xs font-mono tracking-widest uppercase">Lead Response Time: 18 Seconds</span>
      <span class="text-[#00FF41]/60 text-xs">◆</span>
    </div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">

    <!-- Status badge -->
    <div class="section-label mb-10 animate-fade-up">
      <span class="w-2 h-2 rounded-full bg-[#00FF41] animate-pulse-green"></span>
      AI SALES INFRASTRUCTURE · LIVE
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black leading-[0.92] tracking-tight mb-8 animate-fade-up delay-100">
      <span class="block text-white">Your Lead Decay</span>
      <span class="block text-white">is Costing You</span>
      <span class="block text-[#00FF41] relative">
        $25,000+
        <svg class="absolute -right-6 top-0 w-5 h-5 text-[#00FF41]/40 hidden lg:block" viewBox="0 0 24 24" fill="currentColor">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
      </span>
      <span class="block text-white">Every Month.</span>
    </h1>

    <!-- Divider line -->
    <div class="glow-line max-w-sm mx-auto mb-8 animate-fade-up delay-200"></div>

    <!-- Sub-headline -->
    <p class="text-lg md:text-xl text-white/55 max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-up delay-300">
      Manual follow-up is a relic. We install AI Sales Infrastructure that engages, qualifies, and books every lead in
      <span class="text-white font-semibold">&lt;30 seconds</span>.
      Stop burning ad spend. <span class="text-white font-semibold">Start extracting revenue.</span>
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-fade-up delay-400">
      <a
        href="#diagnostic"
        class="neon-btn inline-flex items-center gap-3 px-8 py-4 text-base font-bold rounded-sm w-full sm:w-auto justify-center"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        Run Revenue Audit
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href="#vsl"
        class="inline-flex items-center gap-3 px-8 py-4 text-base font-medium text-white/70 hover:text-white border border-white/10 hover:border-white/25 rounded-sm transition-all w-full sm:w-auto justify-center"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <path d="M8 5v14l11-7z"/>
        </svg>
        Watch Case Study (4:47)
      </a>
    </div>

    <!-- Metrics row -->
    <div class="grid grid-cols-3 gap-px bg-white/5 max-w-2xl mx-auto rounded-sm overflow-hidden animate-fade-up delay-500">
      <div class="bg-[#111] px-6 py-5 text-center">
        <div class="text-2xl md:text-3xl font-black text-[#00FF41] tabular-nums">18s</div>
        <div class="text-xs text-white/40 mt-1 font-medium uppercase tracking-wide">Avg. Response</div>
      </div>
      <div class="bg-[#111] px-6 py-5 text-center">
        <div class="text-2xl md:text-3xl font-black text-white tabular-nums">340%</div>
        <div class="text-xs text-white/40 mt-1 font-medium uppercase tracking-wide">Avg. ROI / 90d</div>
      </div>
      <div class="bg-[#111] px-6 py-5 text-center">
        <div class="text-2xl md:text-3xl font-black text-white tabular-nums">24/7</div>
        <div class="text-xs text-white/40 mt-1 font-medium uppercase tracking-wide">Always On</div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-20 flex flex-col items-center gap-2 text-white/20 animate-fade-up delay-500">
      <span class="text-xs font-mono uppercase tracking-widest">Scroll to see the math</span>
      <div class="w-px h-12 bg-gradient-to-b from-white/20 to-transparent"></div>
    </div>
  </div>
</section>
