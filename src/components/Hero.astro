---
---

<section class="relative bg-[#0A0A0A] overflow-hidden">
  <!-- Background grid -->
  <div class="absolute inset-0 opacity-[0.022] pointer-events-none"
    style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;">
  </div>

  <!-- Radial glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[900px] rounded-full pointer-events-none opacity-[0.05]"
    style="background: radial-gradient(circle, #00FF41 0%, transparent 70%);">
  </div>

  <!-- Main hero content — top-padded, no flex centering (eliminates ticker overlap) -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-40 sm:pt-44 pb-20 text-center">

    <!-- Eyebrow label -->
    <div class="inline-flex items-center gap-2 mb-8 px-4 py-1.5 rounded-full border border-white/10 bg-white/[0.03] animate-fade-up">
      <span class="w-1.5 h-1.5 rounded-full bg-[#00FF41] animate-pulse-green"></span>
      <span class="text-[11px] font-mono uppercase tracking-widest text-white/40">Autonomous AI Lead Infrastructure</span>
    </div>

    <!-- H1 Headline -->
    <h1 class="font-black tracking-tight mb-7 animate-fade-up delay-100" style="line-height: 1.0;">
      <span class="block text-white" style="font-size: clamp(2.8rem, 7vw, 6.5rem);">Stop the Silent</span>
      <span class="block text-white" style="font-size: clamp(2.8rem, 7vw, 6.5rem);">Revenue</span>
      <span class="block" style="font-size: clamp(2.8rem, 7vw, 6.5rem); color: #D4AF37; text-shadow: 0 0 40px rgba(212,175,55,0.55), 0 0 80px rgba(212,175,55,0.25), 0 0 120px rgba(212,175,55,0.1);">Hemorrhage.</span>
    </h1>

    <!-- Glow line -->
    <div class="glow-line max-w-xs mx-auto mb-8 animate-fade-up delay-200"></div>

    <!-- Sub-headline -->
    <p class="text-white/50 max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-up delay-300" style="font-size: clamp(1rem, 2vw, 1.2rem);">
      You're paying for attention you don't own. Every visitor who leaves without a trace is capital evaporated.
      We install the <span class="text-white font-semibold">Autonomous Infrastructure</span> that captures,
      nurtures, and closes your leads <span class="text-white font-semibold">24/7.</span>
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4 mb-16 animate-fade-up delay-400">
      <a
        href="#diagnostic"
        class="neon-btn inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-bold rounded-sm w-full sm:w-auto"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        Run My Revenue Audit
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href="#results"
        class="inline-flex items-center justify-center gap-3 px-8 py-4 text-base font-medium text-white/70 hover:text-white border border-white/10 hover:border-white/25 rounded-sm transition-all w-full sm:w-auto"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
          <polyline points="16 7 22 7 22 13"/>
        </svg>
        See Real Results
      </a>
    </div>

    <!-- Metrics row -->
    <div class="grid grid-cols-3 gap-px bg-white/5 max-w-xl mx-auto rounded-sm overflow-hidden animate-fade-up delay-500">
      <div class="bg-[#111] px-4 py-5 text-center">
        <div class="font-black text-[#00FF41] tabular-nums" style="font-size: clamp(1.4rem, 3vw, 2rem);">18s</div>
        <div class="text-[10px] text-white/35 mt-1 font-medium uppercase tracking-wide">Avg. Response</div>
      </div>
      <div class="bg-[#111] px-4 py-5 text-center">
        <div class="font-black text-white tabular-nums" style="font-size: clamp(1.4rem, 3vw, 2rem);">340%</div>
        <div class="text-[10px] text-white/35 mt-1 font-medium uppercase tracking-wide">ROI / 90 Days</div>
      </div>
      <div class="bg-[#111] px-4 py-5 text-center">
        <div class="font-black text-white tabular-nums" style="font-size: clamp(1.4rem, 3vw, 2rem);">24/7</div>
        <div class="text-[10px] text-white/35 mt-1 font-medium uppercase tracking-wide">Always On</div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 flex flex-col items-center gap-2 text-white/20">
      <span class="text-[10px] font-mono uppercase tracking-widest">Scroll to see the math</span>
      <div class="w-px h-10 bg-gradient-to-b from-white/20 to-transparent"></div>
    </div>
  </div>

  <!-- Ticker tape — in normal flow at bottom of section, no overlap possible -->
  <div class="border-t border-white/5 py-3 overflow-hidden bg-[#0A0A0A]/90">
    <div class="animate-ticker flex gap-20 whitespace-nowrap" aria-hidden="true">
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">$2.4M Revenue Recovered Q1 2026</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">47+ High-Ticket Operators Deployed</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">Average 340% ROI in 90 Days</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">Lead Response Time: 18 Seconds</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">$2.4M Revenue Recovered Q1 2026</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">47+ High-Ticket Operators Deployed</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">Average 340% ROI in 90 Days</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
      <span class="text-white/25 text-xs font-mono tracking-widest uppercase">Lead Response Time: 18 Seconds</span>
      <span class="text-[#00FF41]/50 text-xs">◆</span>
    </div>
  </div>
</section>
