---
---

<section class="relative bg-[#0A0A0A] overflow-hidden">
  <!-- Dot grid — very subtle -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1px, transparent 1px); background-size: 32px 32px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);">
  </div>

  <!-- Gold radial glow — off-center, more dramatic -->
  <div class="absolute pointer-events-none" aria-hidden="true"
    style="top: -10%; left: 50%; transform: translateX(-50%); width: 800px; height: 800px; background: radial-gradient(circle, rgba(212,175,55,0.07) 0%, rgba(0,255,65,0.04) 35%, transparent 70%); border-radius: 50%;">
  </div>

  <!-- Main content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-32 sm:pt-36 pb-0 text-center">

    <!-- Eyebrow -->
    <div class="inline-flex items-center gap-2 mb-5 px-4 py-1.5 rounded-full animate-fade-up"
      style="border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.025);">
      <span class="w-1.5 h-1.5 rounded-full bg-[#00FF41] animate-pulse-green flex-shrink-0"></span>
      <span style="font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.16em; color: rgba(255,255,255,0.35);">Autonomous AI Lead Infrastructure</span>
    </div>

    <!-- H1 — 2 clean lines, tight -->
    <h1 class="font-black animate-fade-up delay-100" style="letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 1.75rem;">
      <span class="block text-white" style="font-size: clamp(3rem, 8vw, 7.5rem);">Stop the Silent Revenue</span>
      <span class="block" style="font-size: clamp(3rem, 8vw, 7.5rem); background: linear-gradient(135deg, #D4AF37 0%, #F5D06B 45%, #C9A227 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; filter: drop-shadow(0 0 32px rgba(212,175,55,0.4));">Hemorrhage.</span>
    </h1>

    <!-- Glow line -->
    <div class="mx-auto mb-7 animate-fade-up delay-200" style="height: 1px; max-width: 260px; background: linear-gradient(90deg, transparent, rgba(212,175,55,0.4), transparent);"></div>

    <!-- Sub-headline -->
    <p class="mx-auto mb-10 leading-relaxed animate-fade-up delay-300"
      style="color: rgba(255,255,255,0.45); font-size: clamp(1rem, 1.8vw, 1.15rem); max-width: 38rem; letter-spacing: -0.01em;">
      You're paying for attention you don't own. Every visitor who leaves without a trace is capital evaporated.
      We install the <span style="color: rgba(255,255,255,0.85); font-weight: 600;">Autonomous Infrastructure</span> that captures,
      nurtures, and closes your leads <span style="color: rgba(255,255,255,0.85); font-weight: 600;">24/7.</span>
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 mb-14 animate-fade-up delay-400">
      <a href="#diagnostic"
        class="neon-btn inline-flex items-center justify-center gap-2.5 px-7 py-3.5 font-bold rounded-sm w-full sm:w-auto"
        style="font-size: 0.9rem; letter-spacing: -0.01em;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        Run My Revenue Audit
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="#results"
        class="inline-flex items-center justify-center gap-2.5 px-7 py-3.5 font-medium rounded-sm transition-all w-full sm:w-auto"
        style="font-size: 0.9rem; color: rgba(255,255,255,0.55); border: 1px solid rgba(255,255,255,0.08); letter-spacing: -0.01em;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
          <polyline points="16 7 22 7 22 13"/>
        </svg>
        See Real Results
      </a>
    </div>

    <!-- Social proof micro-strip -->
    <div class="flex items-center justify-center gap-5 mb-14 animate-fade-up delay-500">
      <div class="flex -space-x-2">
        {['M','J','D','S','K'].map((l, i) => (
          <div class="w-7 h-7 rounded-full border-2 border-[#0A0A0A] flex items-center justify-center text-[10px] font-black"
            style={`background: hsl(${i * 47 + 140}, 30%, 20%); color: rgba(255,255,255,0.7);`}>{l}</div>
        ))}
      </div>
      <span style="font-size: 11px; color: rgba(255,255,255,0.3); letter-spacing: -0.01em;">
        <span style="color: rgba(255,255,255,0.6); font-weight: 700;">47+ operators</span> deployed · avg <span style="color: #00FF41; font-weight: 700;">340% ROI</span>
      </span>
    </div>

    <!-- Metrics row -->
    <div class="grid grid-cols-3 gap-px max-w-lg mx-auto rounded-sm overflow-hidden animate-fade-up delay-500" style="background: rgba(255,255,255,0.04);">
      <div class="px-4 py-5 text-center" style="background: #0F0F0F;">
        <div class="font-black text-[#00FF41] tabular-nums" style="font-size: clamp(1.5rem, 3.5vw, 2.2rem); letter-spacing: -0.03em;">18s</div>
        <div style="font-size: 9px; color: rgba(255,255,255,0.3); margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;">Avg. Response</div>
      </div>
      <div class="px-4 py-5 text-center" style="background: #0F0F0F;">
        <div class="font-black text-white tabular-nums" style="font-size: clamp(1.5rem, 3.5vw, 2.2rem); letter-spacing: -0.03em;">340%</div>
        <div style="font-size: 9px; color: rgba(255,255,255,0.3); margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;">ROI / 90 Days</div>
      </div>
      <div class="px-4 py-5 text-center" style="background: #0F0F0F;">
        <div class="font-black text-white tabular-nums" style="font-size: clamp(1.5rem, 3.5vw, 2.2rem); letter-spacing: -0.03em;">24/7</div>
        <div style="font-size: 9px; color: rgba(255,255,255,0.3); margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;">Always On</div>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="mt-12 flex flex-col items-center gap-2 pb-6" style="color: rgba(255,255,255,0.15);">
      <div class="w-px h-10 bg-gradient-to-b from-transparent via-white/15 to-transparent"></div>
    </div>
  </div>

  <!-- Ticker tape — in normal flow, zero overlap possible -->
  <div style="border-top: 1px solid rgba(255,255,255,0.04); padding: 12px 0; overflow: hidden; background: rgba(10,10,10,0.9);">
    <div class="animate-ticker flex gap-20 whitespace-nowrap" aria-hidden="true">
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">$2.4M Revenue Recovered Q1 2026</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">47+ High-Ticket Operators Deployed</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">Average 340% ROI in 90 Days</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">Lead Response Time: 18 Seconds</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">$2.4M Revenue Recovered Q1 2026</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">47+ High-Ticket Operators Deployed</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">Average 340% ROI in 90 Days</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
      <span style="color: rgba(255,255,255,0.2); font-size: 10px; font-family: monospace; text-transform: uppercase; letter-spacing: 0.14em;">Lead Response Time: 18 Seconds</span>
      <span style="color: rgba(0,255,65,0.35); font-size: 10px;">◆</span>
    </div>
  </div>
</section>
