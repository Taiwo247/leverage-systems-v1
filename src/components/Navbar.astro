---
---

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-center md:justify-between px-6 md:px-12 py-5 border-b border-white/5 backdrop-blur-md bg-[#0A0A0A]/80">
  <!-- Logo: centered on mobile, left on desktop -->
  <a href="/" class="flex items-center gap-3 group">
    <!-- Interlocking L+S in hexagonal frame, #D4AF37 gold, breathe animation -->
    <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-svg" aria-label="LeverageSystems logo">
      <!-- Hexagonal frame -->
      <path d="M20 3 L34.5 11 L34.5 27 L20 35 L5.5 27 L5.5 11 Z" stroke="#D4AF37" stroke-width="1.4" fill="none" stroke-linejoin="round"/>
      <!-- L letterform -->
      <path d="M11 12 L11 28 L19 28" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <!-- S letterform – shares endpoint with L at (19,28), creating interlock -->
      <path d="M29 12 C20 12 18 16.5 24 19 C30 21.5 28.5 25.5 19 28" stroke="#D4AF37" stroke-width="2" stroke-linecap="round" fill="none"/>
    </svg>
    <span class="brand-name text-white tracking-tight text-lg sm:text-xl">leverageSystems</span>
  </a>

  <!-- Center links (desktop) -->
  <div class="hidden md:flex items-center gap-8 text-sm text-white/50 font-medium">
    <a href="#comparison" class="hover:text-white transition-colors">How It Works</a>
    <a href="#engine" class="hover:text-white transition-colors">Features</a>
    <a href="#results" class="hover:text-white transition-colors">Results</a>
  </div>

  <!-- CTA -->
  <a
    href="#diagnostic"
    class="neon-btn hidden md:inline-flex items-center gap-2 px-5 py-2.5 text-sm font-bold rounded-sm"
  >
    Run My Revenue Audit
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </a>

  <!-- Mobile menu toggle – absolute so it doesn't disturb logo centering -->
  <button id="mobile-menu-toggle" class="md:hidden absolute right-6 flex flex-col gap-1.5 p-2" aria-label="Menu">
    <span class="w-5 h-0.5 bg-white block transition-all"></span>
    <span class="w-5 h-0.5 bg-white block transition-all"></span>
    <span class="w-3 h-0.5 bg-white block transition-all"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-[#0A0A0A]/95 backdrop-blur-xl flex flex-col items-center justify-center gap-8 translate-y-full transition-transform duration-300 md:hidden">
  <a href="#comparison" class="text-3xl font-bold text-white" onclick="document.getElementById('mobile-menu').classList.add('translate-y-full')">How It Works</a>
  <a href="#engine" class="text-3xl font-bold text-white" onclick="document.getElementById('mobile-menu').classList.add('translate-y-full')">Features</a>
  <a href="#results" class="text-3xl font-bold text-white" onclick="document.getElementById('mobile-menu').classList.add('translate-y-full')">Results</a>
  <a href="#diagnostic" class="neon-btn mt-4 px-8 py-4 text-lg font-bold rounded-sm" onclick="document.getElementById('mobile-menu').classList.add('translate-y-full')">Run My Revenue Audit</a>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('translate-y-full');
  });
</script>
