# ──────────────────────────────────────────────────────────────────────────────
# LeverageSystems — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Make.com webhook for Revenue Audit form submissions
MAKE_AUDIT_WEBHOOK=https://hook.us2.make.com/YOUR_AUDIT_HOOK_ID

# Make.com webhook for Exit Popup email captures
MAKE_EXIT_WEBHOOK=https://hook.us2.make.com/YOUR_EXIT_HOOK_ID

# Resend — auto follow-up emails (get free API key at resend.com)
RESEND_API_KEY=re_YOUR_API_KEY

# Email addresses
OWNER_EMAIL=you@yourdomain.com
FROM_EMAIL=noreply@yourdomain.com   # must be a verified Resend domain; use onboarding@resend.dev for testing
