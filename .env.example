# Make.com webhook for Revenue Audit form submissions
# Create scenario: Webhooks (Custom webhook) → email / CRM / Slack / GHL
MAKE_AUDIT_WEBHOOK=https://hook.eu1.make.com/YOUR_AUDIT_HOOK_ID

# Make.com webhook for Exit Popup email captures
MAKE_EXIT_WEBHOOK=https://hook.eu1.make.com/YOUR_EXIT_HOOK_ID
